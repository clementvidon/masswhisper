# === DATABASE ===
# PostgreSQL connection string (e.g., Neon, Supabase…)
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# === OpenAI ===
# OpenAI API key — https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# === App Server ===
# Local bind host for the backend.
# - 127.0.0.1 on the VM so the backend stays private behind Nginx.
# - 0.0.0.0 only when you want broader network access.
BIND_HOST=127.0.0.1
# Local server port for the backend (optional override)
PORT=3000

# === Logging ===
# Pretty printing for logs (true/false). Defaults to NODE_ENV !== 'production'.
LOG_PRETTY=true
# Log verbosity: debug | info | warn | error | silent.
# Defaults to 'debug' when pretty, otherwise 'info'.
LOG_LEVEL=info

# === Reddit OAuth2 (script app) ===
# Create a "script" app here: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=<your_reddit_client_id>
REDDIT_CLIENT_SECRET=<your_reddit_client_secret>
REDDIT_USERNAME=<your_reddit_bot_username>
REDDIT_PASSWORD=<your_reddit_password_or_app_password>

# === Topic Runtime ===
TOPIC_SLUG=<topic_slug>
TOPIC_PROMPT_VARIANT=<prompt_variant>
TOPIC_PROMPT_BUNDLE_PATH=/absolute/path/to/private/prompts/<prompt_variant>.json
TOPIC_SOURCES_VARIANT=<sources_variant>
TOPIC_SOURCES_BUNDLE_PATH=/absolute/path/to/private/sources/<sources_variant>.json